rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function validLocation() {
      return request.resource.data.keys().hasAll([
          'userId',
          'teamId',
          'zoneId',
          'timestamp',
          'isActive'
        ]) &&
        request.resource.data.zoneId in [
          'zone-north',
          'zone-south',
          'zone-east',
          'zone-west',
          'zone-concourse-n',
          'zone-concourse-s',
          'zone-entry-main',
          'zone-entry-sec'
        ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if false;
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /teamProgress/{teamId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    match /audit_log/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /teams/{teamId}/memberLocations/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) &&
        validLocation() &&
        request.resource.data.userId == userId &&
        request.resource.data.teamId == teamId &&
        (resource == null || request.time > resource.data.timestamp + duration.value(10, 's'));
    }
  }
}
