# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Set to true only when you explicitly want analytics during local development.
NEXT_PUBLIC_ENABLE_FIREBASE_ANALYTICS=false
# Set to true to enable IndexedDB persistence/cache for Firestore in the browser.
# Keep false in local development unless explicitly needed.
NEXT_PUBLIC_ENABLE_FIRESTORE_PERSISTENCE=false
# Set to true to force long-polling transport (disables fetch streams) for Firestore.
# Useful for local/dev environments with watch stream instability.
NEXT_PUBLIC_FIREBASE_FORCE_LONG_POLLING=true
# Set to true to use Firestore realtime listeners in the browser.
# Keep false in local development if you see watch-stream assertion errors.
NEXT_PUBLIC_ENABLE_FIRESTORE_REALTIME_LISTENERS=false
# Polling interval for admin data hooks when realtime listeners are disabled.
NEXT_PUBLIC_FIRESTORE_POLL_INTERVAL_MS=5000

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin (server-side API routes)
# Use these locally if you are not using Application Default Credentials.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Auth bootstrap automation (server-side only)
# Comma-separated Google account emails that should always be admins.
# Legacy role values such as "admin" or "staff" are normalized to isAdmin=true.
ADMIN_EMAILS=staff@example.com
# Keep false in production. Set true only for intentional local bootstrap.
AUTO_BOOTSTRAP_FIRST_ADMIN=false

# Google Cloud
# Cloud Run sets this automatically; set locally only when needed.
GCLOUD_PROJECT=
# BigQuery-backed audit analytics (optional, server-side).
ENABLE_BIGQUERY_AUDIT=true
GOOGLE_BIGQUERY_DATASET=pulse_analytics
GOOGLE_BIGQUERY_AUDIT_TABLE=audit_events
# Enable Firestore-backed distributed API rate limiting across Cloud Run instances.
ENABLE_DISTRIBUTED_RATE_LIMIT=true

# Build
ANALYZE=false
